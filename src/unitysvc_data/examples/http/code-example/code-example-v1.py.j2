import requests
import os

{% if local_testing %}
# Local testing: connect directly to upstream HTTP endpoint
base_url = os.environ.get('HTTP_RELAY_BASE_URL', 'https://echo.staging.svcmarket.com')
api_key = os.environ.get('HTTP_RELAY_API_KEY', '')
auth = None
headers = {'Authorization': f'Bearer {api_key}'} if api_key else {}
{% else %}
# Access via UnitySVC HTTP Gateway
# SERVICE_BASE_URL is the gateway base URL for this service
base_url = os.environ.get('SERVICE_BASE_URL', '')
# Fall back to echo endpoint if SERVICE_BASE_URL is unset or contains unrendered
# template syntax (e.g. enrollment_vars.code not resolved for multi-enrollment services)
if not base_url or '{' in base_url:
    base_url = 'https://echo.staging.svcmarket.com'
auth = None
headers = {}
{% endif %}

# Send a test HTTP GET request
response = requests.get(
    base_url,
    auth=auth,
    headers=headers,
    timeout=10,
)
print(f'Status: {response.status_code}')
print('connectivity ok')
