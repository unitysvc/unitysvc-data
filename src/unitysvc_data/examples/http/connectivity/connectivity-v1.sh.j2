#!/bin/bash
{% if local_testing %}
# Local testing: connect directly to upstream HTTP endpoint
BASE_URL="${HTTP_RELAY_BASE_URL:-https://echo.staging.svcmarket.com}"
API_KEY="${HTTP_RELAY_API_KEY:-}"
if [[ -n "$API_KEY" ]]; then
    HEADERS=(-H "Authorization: Bearer $API_KEY")
else
    HEADERS=()
fi
{% else %}
# Access via UnitySVC HTTP Gateway
# SERVICE_BASE_URL is the gateway base URL for this service
BASE_URL="$SERVICE_BASE_URL"
HEADERS=()
FALLBACK_URL=https://echo.staging.svcmarket.com
# Fall back to echo endpoint if SERVICE_BASE_URL is empty or contains unrendered
# template syntax (e.g. enrollment_vars.code not resolved for multi-enrollment services)
if [[ -z "${BASE_URL}" ]] || [[ "${BASE_URL}" == *"{"* ]]; then
    BASE_URL=$FALLBACK_URL
fi
{% endif %}

# Send a test HTTP GET request
http_code=$(curl -s --max-time 10 -o /dev/null -w "%{http_code}" "${HEADERS[@]}" "$BASE_URL")
{% if not local_testing %}
# A 401/403 from the gateway means no active enrollment (ops testing context).
# Fall back to echo endpoint to verify basic network connectivity.
if [[ "$http_code" == "401" || "$http_code" == "403" ]] && [[ "$BASE_URL" != "$FALLBACK_URL" ]]; then
    BASE_URL=$FALLBACK_URL
    http_code=$(curl -s --max-time 10 -o /dev/null -w "%{http_code}" "$BASE_URL")
fi
{% endif %}
echo "Status: $http_code"
if [[ "$http_code" != "200" ]]; then
    echo "connectivity failed"
    exit 1
fi
echo "connectivity ok"
