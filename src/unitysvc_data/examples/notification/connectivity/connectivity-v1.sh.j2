#!/bin/bash
set -e -o pipefail

response_file="${TMPDIR:-/tmp}/notification-connectivity-response.json"
auth_args=()
if [ -n "${UNITYSVC_API_KEY:-}" ]; then
    auth_args=(-H "Authorization: Bearer ${UNITYSVC_API_KEY}")
fi
http_code=$(curl -sS -X POST "{{ service_base_url }}/send" \
  "${auth_args[@]}" \
  -H "Content-Type: application/json" \
  -d '{"target":"","message":"unitysvc connectivity test","format":"text"}' \
  -o "${response_file}" \
  -w "%{http_code}")

case "$http_code" in
  2??)
    [ -s "${response_file}" ] || {
      echo "HTTP 2xx but empty body — upstream returned no payload" >&2
      exit 1
    }
    ;;
  *)
    echo "HTTP $http_code from upstream:" >&2
    cat "${response_file}" >&2
    exit 1
    ;;
esac
echo "connectivity ok"
