"""Generic HTTP smoke test for any UnitySVC HTTP-fronted service.

Sends a GET to the rendered base URL and asserts a 2xx response.
"""

import os
import sys

import requests

URL = "{{ service_base_url }}"
TIMEOUT_SECONDS = 5

headers = {}
if api_key := os.environ.get("UNITYSVC_API_KEY"):
    headers["Authorization"] = f"Bearer {api_key}"

try:
    response = requests.get(URL, headers=headers, timeout=TIMEOUT_SECONDS)
except requests.RequestException as exc:
    print(f"connectivity failed: {exc}", file=sys.stderr)
    sys.exit(1)

if not response.ok:
    print(f"connectivity failed: HTTP {response.status_code} from {URL}", file=sys.stderr)
    print(response.text[:500], file=sys.stderr)
    sys.exit(1)

print(f"ok (HTTP {response.status_code})")
print(response.text[:500])
