#!/bin/bash
# Code example for Notify→Slack-compatible transformer services (slack, mattermost, rocketchat, gchat, flock, webex, notifico).
# POST a canonical notification envelope to the HTTP gateway endpoint.
# The gateway transforms it and delivers to the configured upstream channel.
set -o pipefail

GATEWAY_URL="{{ service_base_url }}"

curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer ${UNITYSVC_API_KEY}" \
    -d '{
  "title": "Hello from UnitySVC",
  "body": "Notification delivered via transformer.",
  "from": "user@example.com"
}' \
    -w "\nHTTP %{http_code}\n" \
    "$GATEWAY_URL"

echo "sent"
