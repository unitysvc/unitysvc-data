import os

import httpx

# POST a canonical notification envelope to the HTTP gateway endpoint.
# The gateway transforms it and delivers to the configured upstream channel.
GATEWAY_URL = os.path.expandvars("{{ service_base_url }}")

response = httpx.post(
    GATEWAY_URL,
    headers={"Authorization": f"Bearer {k}"} if (k := os.environ.get("UNITYSVC_API_KEY")) else {},
    json={
        "title": "Hello from UnitySVC",
        "body": "Notification delivered via transformer.",
        "from": "user@example.com",
    },
)
response.raise_for_status()
print(f"sent (HTTP {response.status_code})")
