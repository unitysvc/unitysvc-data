import os

import requests

base_url = os.environ["SERVICE_BASE_URL"]
api_key = os.environ["UNITYSVC_API_KEY"]

# Trigger an uptime check. In gateway mode the bridge knows the
# check parameters from the enrollment; in local-testing mode the
# harness injects them from `ops_testing_parameters`.
response = requests.post(
    base_url,
    headers={"Authorization": f"Bearer {api_key}"},
{%- if local_testing %}
    json={{ listing.service_options.ops_testing_parameters | tojson }},
{%- endif %}
)
response.raise_for_status()

result = response.json()
print(f"Status: {result['status']}")
print(f"Response time: {result['metrics']['response_ms']}ms")
