import os

import httpx

{% if local_testing %}
WEBHOOK_URL = "{{ service_base_url }}${__webhook_path__}"

response = httpx.post(
    WEBHOOK_URL,
    json={
        "jsonrpc": "2.0",
        "method": "GUI.ShowNotification",
        "params": {
            "title": "Hello from UnitySVC",
            "message": "Notification sent via pass-through service",
            "displaytime": 12000
        },
        "id": 1
    },
)
{% else %}
GATEWAY_URL = "{{ service_base_url }}"

response = httpx.post(
    GATEWAY_URL,
    headers={"Authorization": f"Bearer {os.environ['UNITYSVC_API_KEY']}"},
    json={
        "jsonrpc": "2.0",
        "method": "GUI.ShowNotification",
        "params": {
            "title": "Hello from UnitySVC",
            "message": "Notification sent via pass-through service",
            "displaytime": 12000
        },
        "id": 1
    },
)
{% endif %}
response.raise_for_status()
print(f"sent (HTTP {response.status_code})")
