import os

import httpx

{% if local_testing %}
WEBHOOK_URL = "{{ service_base_url }}${__webhook_path__}"

response = httpx.post(
    WEBHOOK_URL,
    data={
        "From": "+15551234567",
        "To": "+15559876543",
        "Body": "Hello from UnitySVC"
    },
)
{% else %}
GATEWAY_URL = "{{ service_base_url }}"

response = httpx.post(
    GATEWAY_URL,
    headers={"Authorization": f"Bearer {os.environ['UNITYSVC_API_KEY']}"},
    data={
        "From": "+15551234567",
        "To": "+15559876543",
        "Body": "Hello from UnitySVC"
    },
)
{% endif %}
response.raise_for_status()
print(f"sent (HTTP {response.status_code})")
