import os

import httpx

{% if local_testing %}
WEBHOOK_URL = "{{ service_base_url }}${__webhook_path__}"

response = httpx.post(
    WEBHOOK_URL,
    json={
        "to": "+15551234567",
        "body": "Hello from UnitySVC",
        "routingGroup": "STANDARD",
        "encoding": "TEXT",
        "deliveryReports": "ERRORS"
    },
)
{% else %}
GATEWAY_URL = "{{ service_base_url }}"

response = httpx.post(
    GATEWAY_URL,
    headers={"Authorization": f"Bearer {os.environ['UNITYSVC_API_KEY']}"},
    json={
        "to": "+15551234567",
        "body": "Hello from UnitySVC",
        "routingGroup": "STANDARD",
        "encoding": "TEXT",
        "deliveryReports": "ERRORS"
    },
)
{% endif %}
response.raise_for_status()
print(f"sent (HTTP {response.status_code})")
