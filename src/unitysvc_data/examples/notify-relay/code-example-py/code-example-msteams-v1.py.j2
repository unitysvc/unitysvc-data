import os

import httpx

{% if local_testing %}
WEBHOOK_URL = "{{ service_base_url }}${__webhook_path__}"

response = httpx.post(
    WEBHOOK_URL,
    json={
        "@type": "MessageCard",
        "@context": "https://schema.org/extensions",
        "themeColor": "0076D7",
        "text": "Hello from UnitySVC",
        "sections": [{"activityText": "Notification sent via pass-through service."}],
    },
)
{% else %}
GATEWAY_URL = "{{ service_base_url }}"

response = httpx.post(
    GATEWAY_URL,
    headers={"Authorization": f"Bearer {os.environ['UNITYSVC_API_KEY']}"},
    json={
        "@type": "MessageCard",
        "@context": "https://schema.org/extensions",
        "themeColor": "0076D7",
        "text": "Hello from UnitySVC",
        "sections": [{"activityText": "Notification sent via pass-through service."}],
    },
)
{% endif %}
response.raise_for_status()
print(f"sent (HTTP {response.status_code})")
