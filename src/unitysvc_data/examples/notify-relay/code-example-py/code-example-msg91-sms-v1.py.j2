import os

import httpx

{% if local_testing %}
WEBHOOK_URL = "{{ service_base_url }}${__webhook_path__}"

response = httpx.post(
    WEBHOOK_URL,
    json={
        "template_id": "test_tmpl",
        "short_url": 0,
        "recipients": [
            {
                "mobiles": "15551234567",
                "body": "Hello from UnitySVC",
                "type": "info"
            }
        ]
    },
)
{% else %}
GATEWAY_URL = "{{ service_base_url }}"

response = httpx.post(
    GATEWAY_URL,
    headers={"Authorization": f"Bearer {os.environ['UNITYSVC_API_KEY']}"},
    json={
        "template_id": "test_tmpl",
        "short_url": 0,
        "recipients": [
            {
                "mobiles": "15551234567",
                "body": "Hello from UnitySVC",
                "type": "info"
            }
        ]
    },
)
{% endif %}
response.raise_for_status()
print(f"sent (HTTP {response.status_code})")
