import os

import httpx

{% if local_testing %}
WEBHOOK_URL = "{{ service_base_url }}${__webhook_path__}"

response = httpx.post(
    WEBHOOK_URL,
    data={
        "apikey": "test_key",
        "application": "UnitySVC",
        "event": "Hello from UnitySVC",
        "description": "Notification sent via pass-through service",
        "priority": "0"
    },
)
{% else %}
GATEWAY_URL = "{{ service_base_url }}"

response = httpx.post(
    GATEWAY_URL,
    headers={"Authorization": f"Bearer {os.environ['UNITYSVC_API_KEY']}"},
    data={
        "apikey": "test_key",
        "application": "UnitySVC",
        "event": "Hello from UnitySVC",
        "description": "Notification sent via pass-through service",
        "priority": "0"
    },
)
{% endif %}
response.raise_for_status()
print(f"sent (HTTP {response.status_code})")
