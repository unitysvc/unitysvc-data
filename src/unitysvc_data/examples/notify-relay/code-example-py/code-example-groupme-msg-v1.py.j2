import os

import httpx

{% if local_testing %}
# Local mode: POST GroupMe payload directly to the upstream endpoint.
WEBHOOK_URL = "{{ service_base_url }}${{'__webhook_path__'}}"

response = httpx.post(
    WEBHOOK_URL,
    json={"text":"connectivity check","bot_id":"test_bot_id"},
)
response.raise_for_status()
print(f"sent (HTTP {response.status_code})")

{% else %}
# Gateway mode: POST the notification payload to the UnitySVC gateway.
GATEWAY_URL = "{{ service_base_url }}"

response = httpx.post(
    GATEWAY_URL,
    headers={"Authorization": f"Bearer {os.environ['UNITYSVC_API_KEY']}"},
    json={
            "text": "connectivity check",
            "bot_id": "test_bot_id"
        },
)
response.raise_for_status()
print(f"sent (HTTP {response.status_code})")
{% endif %}
