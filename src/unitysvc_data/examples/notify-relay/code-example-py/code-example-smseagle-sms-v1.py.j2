import os

import httpx

{% if local_testing %}
WEBHOOK_URL = "{{ service_base_url }}${__webhook_path__}"

response = httpx.post(
    WEBHOOK_URL,
    json={
        "method": "sms.send_sms",
        "params": {
            "access_token": "test_key",
            "to": "+15551234567",
            "message": "Hello from UnitySVC",
            "message_type": "sms"
        }
    },
)
{% else %}
GATEWAY_URL = "{{ service_base_url }}"

response = httpx.post(
    GATEWAY_URL,
    headers={"Authorization": f"Bearer {os.environ['UNITYSVC_API_KEY']}"},
    json={
        "method": "sms.send_sms",
        "params": {
            "access_token": "test_key",
            "to": "+15551234567",
            "message": "Hello from UnitySVC",
            "message_type": "sms"
        }
    },
)
{% endif %}
response.raise_for_status()
print(f"sent (HTTP {response.status_code})")
