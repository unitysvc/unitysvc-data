import os

import httpx

{% if local_testing %}
WEBHOOK_URL = "{{ service_base_url }}${__webhook_path__}"

response = httpx.post(
    WEBHOOK_URL,
    json={
        "priority": "info",
        "icon_type": "none",
        "lifetime": 120000,
        "model": {
            "cycles": 1,
            "frames": [
                {
                    "icon": 1,
                    "text": "Hello from UnitySVC"
                }
            ]
        }
    },
)
{% else %}
GATEWAY_URL = "{{ service_base_url }}"

response = httpx.post(
    GATEWAY_URL,
    headers={"Authorization": f"Bearer {os.environ['UNITYSVC_API_KEY']}"},
    json={
        "priority": "info",
        "icon_type": "none",
        "lifetime": 120000,
        "model": {
            "cycles": 1,
            "frames": [
                {
                    "icon": 1,
                    "text": "Hello from UnitySVC"
                }
            ]
        }
    },
)
{% endif %}
response.raise_for_status()
print(f"sent (HTTP {response.status_code})")
