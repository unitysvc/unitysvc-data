import os

import httpx

{% if local_testing %}
WEBHOOK_URL = "{{ service_base_url }}${__webhook_path__}"

response = httpx.post(
    WEBHOOK_URL,
    data={
        "access_token": "test_token",
        "type": "donation",
        "message": "Hello from UnitySVC",
        "user_massage": "Notification sent via pass-through service"
    },
)
{% else %}
GATEWAY_URL = "{{ service_base_url }}"

response = httpx.post(
    GATEWAY_URL,
    headers={"Authorization": f"Bearer {os.environ['UNITYSVC_API_KEY']}"},
    data={
        "access_token": "test_token",
        "type": "donation",
        "message": "Hello from UnitySVC",
        "user_massage": "Notification sent via pass-through service"
    },
)
{% endif %}
response.raise_for_status()
print(f"sent (HTTP {response.status_code})")
