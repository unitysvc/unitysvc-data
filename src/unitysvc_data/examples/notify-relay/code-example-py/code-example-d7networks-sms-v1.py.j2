import os

import httpx

{% if local_testing %}
WEBHOOK_URL = "{{ service_base_url }}${__webhook_path__}"

response = httpx.post(
    WEBHOOK_URL,
    json={
        "message_globals": {
            "channel": "sms",
            "originator": "source"
        },
        "messages": [
            {
                "recipients": [
                    "+15551234567"
                ],
                "content": "Hello from UnitySVC",
                "data_coding": "auto"
            }
        ]
    },
)
{% else %}
GATEWAY_URL = "{{ service_base_url }}"

response = httpx.post(
    GATEWAY_URL,
    headers={"Authorization": f"Bearer {os.environ['UNITYSVC_API_KEY']}"},
    json={
        "message_globals": {
            "channel": "sms",
            "originator": "source"
        },
        "messages": [
            {
                "recipients": [
                    "+15551234567"
                ],
                "content": "Hello from UnitySVC",
                "data_coding": "auto"
            }
        ]
    },
)
{% endif %}
response.raise_for_status()
print(f"sent (HTTP {response.status_code})")
