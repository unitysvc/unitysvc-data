import os

import httpx

{% if local_testing %}
WEBHOOK_URL = "{{ service_base_url }}${__webhook_path__}"

# local test token — real services use credentials from service config
response = httpx.post(
    WEBHOOK_URL,
    headers={"Authorization": "Bearer demotoken"},
    json={
        "msgtype": "m.text",
        "body": "Hello from UnitySVC\nNotification sent via pass-through service.",
    },
)
{% else %}
GATEWAY_URL = "{{ service_base_url }}"

response = httpx.post(
    GATEWAY_URL,
    headers={"Authorization": f"Bearer {os.environ['UNITYSVC_API_KEY']}"},
    json={
        "msgtype": "m.text",
        "body": "Hello from UnitySVC\nNotification sent via pass-through service.",
    },
)
{% endif %}
response.raise_for_status()
print(f"sent (HTTP {response.status_code})")
