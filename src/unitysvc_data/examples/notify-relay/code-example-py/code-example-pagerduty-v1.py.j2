import os

import httpx

{% if local_testing %}
# Local mode: POST PagerDuty payload directly to the upstream endpoint.
WEBHOOK_URL = "{{ service_base_url }}${{'__webhook_path__'}}"

response = httpx.post(
    WEBHOOK_URL,
    json={"routing_key":"test_key","event_action":"trigger","payload":{"summary":"connectivity check","severity":"error","source":"test@example.com","custom_details":{"body":"ping"}}},
)
response.raise_for_status()
print(f"sent (HTTP {response.status_code})")

{% else %}
# Gateway mode: POST the notification payload to the UnitySVC gateway.
GATEWAY_URL = "{{ service_base_url }}"

response = httpx.post(
    GATEWAY_URL,
    headers={"Authorization": f"Bearer {os.environ['UNITYSVC_API_KEY']}"},
    json={
            "routing_key": "test_key",
            "event_action": "trigger",
            "payload": {
                "summary": "connectivity check",
                "severity": "error",
                "source": "test@example.com",
                "custom_details": {
                    "body": "ping"
                }
            }
        },
)
response.raise_for_status()
print(f"sent (HTTP {response.status_code})")
{% endif %}
