#!/bin/bash
# Connectivity test for GroupMe notification relay services.
# Local mode: POST a GroupMe ping to the upstream endpoint.
# Gateway mode: POST the GroupMe payload via the UnitySVC gateway.
set -o pipefail

{% if local_testing %}
WEBHOOK_URL="{{ service_base_url }}${{'__webhook_path__'}}"

status=$(curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -d '{"text":"connectivity check","bot_id":"test_bot_id"}' \
    -o /dev/null -w "%{http_code}" \
    "$WEBHOOK_URL" 2>/dev/null)

case "$status" in
  2??) echo "connectivity ok (HTTP $status)"; exit 0 ;;
  000) echo "connectivity failed: could not connect to $WEBHOOK_URL" >&2; exit 1 ;;
  *)   echo "connectivity failed: HTTP $status from $WEBHOOK_URL" >&2; exit 1 ;;
esac

{% else %}
GATEWAY_URL="{{ service_base_url }}"

status=$(curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer ${UNITYSVC_API_KEY}" \
    -d '{"text":"connectivity check","bot_id":"test_bot_id"}' \
    -o /dev/null -w "%{http_code}" \
    "$GATEWAY_URL" 2>/dev/null)

case "$status" in
  2??) echo "connectivity ok (HTTP $status)"; exit 0 ;;
  000) echo "connectivity failed: could not connect to $GATEWAY_URL" >&2; exit 1 ;;
  *)   echo "connectivity failed: HTTP $status from $GATEWAY_URL" >&2; exit 1 ;;
esac
{% endif %}
