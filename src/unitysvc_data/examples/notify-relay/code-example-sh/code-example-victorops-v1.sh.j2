#!/bin/bash
# Code example for VictorOps notification relay services.
set -o pipefail

{% if local_testing %}
WEBHOOK_URL="{{ service_base_url }}${{'__webhook_path__'}}"

curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -d '{"message_type":"CRITICAL","entity_display_name":"connectivity check","state_message":"ping"}' \
    -w "\nHTTP %{http_code}\n" \
    "$WEBHOOK_URL"

echo "sent"

{% else %}
GATEWAY_URL="{{ service_base_url }}"

curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer ${UNITYSVC_API_KEY}" \
    -d '{"message_type":"CRITICAL","entity_display_name":"connectivity check","state_message":"ping"}' \
    -w "\nHTTP %{http_code}\n" \
    "$GATEWAY_URL"

echo "sent"
{% endif %}
