#!/bin/bash
# Send a octopush sms notification via pass-through service.
# Local mode: POST the octopush sms payload directly to the upstream webhook.
# Gateway mode: POST the same octopush sms payload via the UnitySVC gateway (adds Bearer auth).
set -o pipefail

{% if local_testing %}
WEBHOOK_URL="{{ service_base_url }}${__webhook_path__}"

status=$(curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -d '{"recipients": [{"phone_number": "+15551234567"}], "text": "Hello from UnitySVC", "type": "sms_premium", "purpose": "alert", "sender": "src", "with_replies": false}' \
    -o /dev/null -w "%{http_code}" \
    "$WEBHOOK_URL" 2>/dev/null)

case "$status" in
  2??) echo "sent"; exit 0 ;;
  000) echo "request failed: could not connect to $WEBHOOK_URL" >&2; exit 1 ;;
  *)   echo "request failed: HTTP $status from $WEBHOOK_URL" >&2; exit 1 ;;
esac

{% else %}
GATEWAY_URL="{{ service_base_url }}"

status=$(curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer ${UNITYSVC_API_KEY}" \
    -d '{"recipients": [{"phone_number": "+15551234567"}], "text": "Hello from UnitySVC", "type": "sms_premium", "purpose": "alert", "sender": "src", "with_replies": false}' \
    -o /dev/null -w "%{http_code}" \
    "$GATEWAY_URL" 2>/dev/null)

case "$status" in
  2??) echo "sent"; exit 0 ;;
  000) echo "request failed: could not connect to $GATEWAY_URL" >&2; exit 1 ;;
  *)   echo "request failed: HTTP $status from $GATEWAY_URL" >&2; exit 1 ;;
esac
{% endif %}
