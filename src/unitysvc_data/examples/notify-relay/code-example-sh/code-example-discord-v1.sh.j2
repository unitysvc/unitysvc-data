#!/bin/bash
# Send a discord notification via pass-through service.
# Local mode: POST discord embeds directly to the upstream webhook.
# Gateway mode: POST the same discord payload via the UnitySVC gateway (adds Bearer auth).
set -o pipefail

{% if local_testing %}
WEBHOOK_URL="{{ service_base_url }}${__webhook_path__}"

status=$(curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -d '{
  "embeds": [{
    "title": "Hello from UnitySVC",
    "description": "Notification sent via pass-through service",
    "footer": {"text": "from user@example.com"}
  }]
}' \
    -o /dev/null -w "%{http_code}" \
    "$WEBHOOK_URL" 2>/dev/null)

case "$status" in
  204) echo "sent"; exit 0 ;;
  000) echo "request failed: could not connect to $WEBHOOK_URL" >&2; exit 1 ;;
  *)   echo "request failed: HTTP $status from $WEBHOOK_URL" >&2; exit 1 ;;
esac

{% else %}
GATEWAY_URL="{{ service_base_url }}"

status=$(curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer ${UNITYSVC_API_KEY}" \
    -d '{
  "embeds": [{
    "title": "Hello from UnitySVC",
    "description": "Notification sent via pass-through service",
    "footer": {"text": "from user@example.com"}
  }]
}' \
    -o /dev/null -w "%{http_code}" \
    "$GATEWAY_URL" 2>/dev/null)

case "$status" in
  2??) echo "sent"; exit 0 ;;
  000) echo "request failed: could not connect to $GATEWAY_URL" >&2; exit 1 ;;
  *)   echo "request failed: HTTP $status from $GATEWAY_URL" >&2; exit 1 ;;
esac
{% endif %}
