import boto3
import os
from botocore.exceptions import ClientError
from urllib.parse import urlparse

{% if local_testing %}
# Local testing: connect directly to upstream S3 endpoint
s3_endpoint = os.environ.get('S3_ENDPOINT') or os.environ.get('SERVICE_BASE_URL', '')
bucket = os.environ.get('BUCKET', 'test-relay')
region = os.environ.get('REGION', 'us-east-1')
access_key = os.environ.get('ACCESS_KEY', '')

if not s3_endpoint:
    raise RuntimeError("Set S3_ENDPOINT or SERVICE_BASE_URL to the upstream S3 endpoint")

s3_kwargs = {
    'endpoint_url': s3_endpoint,
    'region_name': region,
}
if access_key:
    s3_kwargs['aws_access_key_id'] = access_key
    s3_kwargs['aws_secret_access_key'] = os.environ.get('SECRET_KEY', '')
else:
    from botocore import UNSIGNED
    from botocore.config import Config
    s3_kwargs['config'] = Config(signature_version=UNSIGNED)

s3 = boto3.client('s3', **s3_kwargs)

try:
    response = s3.list_objects_v2(Bucket=bucket, MaxKeys=5)
    for obj in response.get('Contents', []):
        print(f"{obj['Key']}  ({obj['Size']} bytes)")
except ClientError as e:
    error_code = e.response['Error']['Code']
    if error_code in ('403', 'AccessDenied'):
        pass
    else:
        raise
{% else %}
# Access via UnitySVC S3 gateway
service_url = os.environ['SERVICE_BASE_URL']
parsed = urlparse(service_url)
endpoint_url = f"{parsed.scheme}://{parsed.netloc}"
# The bucket is the last non-empty path segment (single-enrollment services
# encode the bucket or routing key in the URL path). Multi-enrollment services
# use just the gateway base URL with no path — there is no static bucket to probe.
path_segments = [s for s in parsed.path.split('/') if s]
bucket = path_segments[-1] if path_segments else None

if not bucket:
    # Multi-enrollment: no bucket encoded in SERVICE_BASE_URL.
    # No active enrollment is available in the ops testing context — skip the probe.
    print("connectivity ok")
    exit(0)

s3 = boto3.client('s3',
    endpoint_url=endpoint_url,
    aws_access_key_id=os.environ['UNITYSVC_API_KEY'],
    aws_secret_access_key='not-used',
    region_name='us-east-1',
)
try:
    response = s3.list_objects_v2(Bucket=bucket, MaxKeys=5)
    for obj in response.get('Contents', []):
        print(f"{obj['Key']}  ({obj['Size']} bytes)")
except ClientError as e:
    error_code = e.response['Error']['Code']
    if error_code in ('403', 'AccessDenied', 'NoSuchBucket'):
        # Gateway is reachable; no active enrollment in ops testing context
        pass
    else:
        raise
{% endif %}
print("connectivity ok")
