#!/bin/bash
# Connectivity test for a UnitySVC Notify gateway-transformer channel.
#   local_testing : POST the channel-NATIVE body straight to a mock upstream
#                   (local_url).  No gateway to transform it, no platform auth.
#   gateway       : POST the canonical envelope to service_base_url@<channel>;
#                   the gateway transforms it into the upstream-native payload
#                   and forwards it (Bearer auth).
# The native_body / local_url parameters hold the local-mode upstream test
# payload and URL; the channel parameter selects the transformer channel.
set -o pipefail

{% if local_testing %}
URL="${__local_url__}"
status=$(curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -d '${__native_body__}' \
    -o /dev/null -w "%{http_code}" \
    "$URL" 2>/dev/null)
{% else %}
URL="{{ service_base_url }}@${__channel__}"
status=$(curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer ${UNITYSVC_API_KEY}" \
    -d '{"title":"connectivity check","body":"ping","type":"info","format":"text"}' \
    -o /dev/null -w "%{http_code}" \
    "$URL" 2>/dev/null)
{% endif %}

case "$status" in
  2??) echo "connectivity ok (HTTP $status)"; exit 0 ;;
  000) echo "connectivity failed: could not connect to $URL" >&2; exit 1 ;;
  *)   echo "connectivity failed: HTTP $status from $URL" >&2; exit 1 ;;
esac
