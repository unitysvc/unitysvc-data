#!/bin/bash
# Connectivity test for a UnitySVC Notify gateway-transformer channel (dot).
#   local_testing : POST the channel-NATIVE dot body (baked in) straight to
#                   a mock upstream (local_url).  No gateway to transform it, no
#                   platform auth.
#   gateway       : POST the canonical envelope to service_base_url;
#                   the gateway transforms it into the dot-native payload and
#                   forwards it (Bearer auth).
# The dot-native body is baked into this variant — only the local_url (mock
# upstream) and channel (transformer selector) parameters are supplied.
set -o pipefail

{% if local_testing %}
URL="${__local_url__}"
status=$(curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -d '{"refreshNow": true, "title": "t", "message": "hi"}' \
    -o /dev/null -w "%{http_code}" \
    "$URL" 2>/dev/null)
{% else %}
URL="{{ service_base_url }}"
status=$(curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer ${UNITYSVC_API_KEY}" \
    -d '{"title":"t","body":"hi","type":"info","format":"text"}' \
    -o /dev/null -w "%{http_code}" \
    "$URL" 2>/dev/null)
{% endif %}

case "$status" in
  2??) echo "connectivity ok (HTTP $status)"; exit 0 ;;
  000) echo "connectivity failed: could not connect to $URL" >&2; exit 1 ;;
  *)   echo "connectivity failed: HTTP $status from $URL" >&2; exit 1 ;;
esac
