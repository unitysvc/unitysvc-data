import os

import requests

voice = os.environ.get("VOICE", "alloy")
output_file = os.environ.get("OUTPUT_FILE", "tts_output.wav")

response = requests.post(
    "{{ service_base_url }}/audio/speech",
    headers={
        "Authorization": f"Bearer {os.environ['UNITYSVC_API_KEY']}",
        "Content-Type": "application/json",
    },
    json={
        "model": "{{ routing_key.model }}",
        "input": "I love building and shipping new features for our users!",
        "voice": voice,
        "response_format": "wav",
    },
)
response.raise_for_status()

with open(output_file, "wb") as f:
    f.write(response.content)
print(f"Saved {output_file}")
