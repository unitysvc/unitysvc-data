import os
import urllib.request

import requests

image_url = os.environ.get(
    "IMAGE_URL",
    "https://upload.wikimedia.org/wikipedia/commons/3/3a/Cat03.jpg",
)
prompt = os.environ.get("PROMPT", "Turn this into a cinematic cyberpunk scene")
strength = os.environ.get("STRENGTH", "0.6")
output_file = os.environ.get("OUTPUT_FILE", "output.png")

with urllib.request.urlopen(image_url, timeout=30) as resp:
    image_bytes = resp.read()

response = requests.post(
    "{{ service_base_url }}${__version_prefix__}/models/{{ routing_key.model }}",
    headers={"Authorization": f"Bearer {os.environ['UNITYSVC_API_KEY']}"},
    files={"image": ("input.png", image_bytes)},
    data={"prompt": prompt, "strength": strength},
)
response.raise_for_status()
with open(output_file, "wb") as f:
    f.write(response.content)
print(f"Saved {output_file}")
