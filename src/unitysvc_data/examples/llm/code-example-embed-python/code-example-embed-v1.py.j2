import os

import requests

UNITYSVC_API_KEY = os.environ.get("UNITYSVC_API_KEY")
SERVICE_BASE_URL = os.environ.get("SERVICE_BASE_URL")
MODEL = os.environ.get("MODEL", "{{ offering.name }}")

headers = {
    "Authorization": f"Bearer {UNITYSVC_API_KEY}",
    "Content-Type": "application/json",
}

payload = {
    "model": MODEL,
    "input": [
        "Embed this sentence.",
        "As well as this one.",
    ],
}

response = requests.post(SERVICE_BASE_URL, headers=headers, json=payload)

if response.status_code != 200:
    print(f"Error {response.status_code}: {response.text}")
    raise SystemExit(1)

data = response.json()
for item in data.get("data", []):
    vec = item.get("embedding", [])
    print(f"index={item.get('index')} dim={len(vec)} first3={vec[:3]}")
