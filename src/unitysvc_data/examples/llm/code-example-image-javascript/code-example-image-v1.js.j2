import { writeFile } from "fs/promises";

async function main() {
  const prompt = process.env.PROMPT || "An astronaut riding a horse on Mars";
  const outputFile = process.env.OUTPUT_FILE || "image.png";

  const response = await fetch("{{ service_base_url }}/v1/images/generations", {
    method: "POST",
    headers: {
      Authorization: `Bearer ${process.env.UNITYSVC_API_KEY}`,
      "Content-Type": "application/json",
    },
    body: JSON.stringify({
      model: "{{ routing_key.model }}",
      prompt,
      n: 1,
      size: "1024x1024",
      response_format: "b64_json",
    }),
  });
  if (!response.ok) {
    throw new Error(`HTTP ${response.status}: ${await response.text()}`);
  }
  const data = await response.json();
  const imageB64 = data.data[0].b64_json;
  await writeFile(outputFile, Buffer.from(imageB64, "base64"));
  console.log(`Saved ${outputFile}`);
}

main().catch((err) => {
  console.error(err.message);
  process.exit(1);
});
