async function main() {
  const response = await fetch("{{ service_base_url }}/v1/rerank", {
    method: "POST",
    headers: {
      Authorization: `Bearer ${process.env.UNITYSVC_API_KEY}`,
      "Content-Type": "application/json",
    },
    body: JSON.stringify({
      model: "{{ routing_key.model }}",
      query: "What is the capital of the United States?",
      top_n: 3,
      documents: [
        "Carson City is the capital of Nevada.",
        "Saipan is the capital of the Northern Mariana Islands.",
        "Washington, D.C. is the capital of the United States.",
        "Capitalization is the use of a capital letter at the start of a word.",
        "Capital punishment has existed in the United States for centuries.",
      ],
    }),
  });
  if (!response.ok) {
    throw new Error(`HTTP ${response.status}: ${await response.text()}`);
  }
  console.log(JSON.stringify(await response.json(), null, 2));
}

main().catch((err) => {
  console.error(err.message);
  process.exit(1);
});
