import json
import os

import requests


def echo_message(message: str) -> str:
    return f"Echo: {message}"


response = requests.post(
    "{{ service_base_url }}/v1/chat/completions",
    headers={
        "Authorization": f"Bearer {os.environ['UNITYSVC_API_KEY']}",
        "Content-Type": "application/json",
    },
    json={
        "model": "{{ routing_key.model }}",
        "messages": [
            {"role": "system", "content": "You are a helpful assistant."},
            {"role": "user", "content": "Echo back: this is a test"},
        ],
        "tools": [
            {
                "type": "function",
                "function": {
                    "name": "echo_message",
                    "description": "Echoes back the given message",
                    "parameters": {
                        "type": "object",
                        "properties": {
                            "message": {"type": "string", "description": "The message to echo"},
                        },
                        "required": ["message"],
                    },
                },
            }
        ],
        "tool_choice": "auto",
    },
)
# Surface the upstream body on 4xx / 5xx; ``raise_for_status`` alone
# loses the gateway's reason ("400 Client Error" with no detail).
if not response.ok:
    raise SystemExit(f"HTTP {response.status_code}: {response.text}")

message = response.json()["choices"][0]["message"]
tool_calls = message.get("tool_calls") or []
if tool_calls:
    for tool_call in tool_calls:
        args = json.loads(tool_call["function"]["arguments"])
        if tool_call["function"]["name"] == "echo_message":
            print(echo_message(args["message"]))
else:
    print(message.get("content", ""))
