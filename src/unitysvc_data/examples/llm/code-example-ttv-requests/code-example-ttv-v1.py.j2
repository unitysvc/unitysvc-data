import os

import requests

prompt = os.environ.get(
    "PROMPT",
    "A cinematic shot of a futuristic city at sunset, flying drones, ultra realistic",
)
output_file = os.environ.get("OUTPUT_FILE", "output.mp4")

response = requests.post(
    "{{ service_base_url }}${__version_prefix__}/models/{{ routing_key.model }}",
    headers={"Authorization": f"Bearer {os.environ['UNITYSVC_API_KEY']}"},
    json={"inputs": prompt},
)
response.raise_for_status()
with open(output_file, "wb") as f:
    f.write(response.content)
print(f"Saved {output_file}")
