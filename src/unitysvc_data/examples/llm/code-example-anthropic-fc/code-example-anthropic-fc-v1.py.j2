import os

from anthropic import Anthropic


def echo_message(message: str) -> str:
    return f"Echo: {message}"


client = Anthropic(
    base_url="{{ service_base_url }}",
    api_key=os.environ["UNITYSVC_API_KEY"],
)

response = client.messages.create(
    model="{{ routing_key.model }}",
    max_tokens=1024,
    system="You are a helpful assistant.",
    messages=[
        {"role": "user", "content": "Echo back: this is a test"},
    ],
    tools=[
        {
            "name": "echo_message",
            "description": "Echoes back the given message",
            "input_schema": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string",
                        "description": "The message to echo",
                    },
                },
                "required": ["message"],
            },
        }
    ],
)

# Anthropic returns mixed content blocks; tool calls appear as
# ``type=tool_use`` items rather than a top-level ``tool_calls`` field.
tool_used = False
for block in response.content:
    if block.type == "tool_use" and block.name == "echo_message":
        print(echo_message(block.input["message"]))
        tool_used = True

if not tool_used:
    text_blocks = [b.text for b in response.content if b.type == "text"]
    print("\n".join(text_blocks))
