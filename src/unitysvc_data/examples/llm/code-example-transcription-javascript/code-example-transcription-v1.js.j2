async function main() {
  const audioUrl =
    process.env.AUDIO_URL ||
    "https://raw.githubusercontent.com/openai/whisper/main/tests/jfk.flac";

  const audio = await fetch(audioUrl);
  if (!audio.ok) {
    throw new Error(`failed to fetch audio: HTTP ${audio.status}`);
  }
  const audioBytes = new Uint8Array(await audio.arrayBuffer());
  const filename = audioUrl.split("/").pop().split("?")[0] || "audio";

  const form = new FormData();
  form.append("model", "{{ routing_key.model }}");
  form.append("language", "${__language__}");
  form.append("file", new Blob([audioBytes]), filename);

  const response = await fetch("{{ service_base_url }}${__version_prefix__}/audio/transcriptions", {
    method: "POST",
    headers: {
      Authorization: `Bearer ${process.env.UNITYSVC_API_KEY}`,
    },
    body: form,
  });

  if (!response.ok) {
    throw new Error(`HTTP ${response.status}: ${await response.text()}`);
  }
  const result = await response.json();
  console.log(result.text);
}

main().catch((err) => {
  console.error(err.message);
  process.exit(1);
});
