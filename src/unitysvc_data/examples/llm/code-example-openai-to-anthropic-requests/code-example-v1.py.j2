# OpenAI-format chat-completion example for an openai->anthropic service: the
# customer speaks OpenAI; the upstream is Anthropic. Uses `requests` so the same
# example renders for either side of the translation.
#
#   local_testing : call the Anthropic UPSTREAM directly (Anthropic Messages).
#   otherwise     : call the gateway in OpenAI format; it translates to Anthropic.
import os

import requests

{% if local_testing %}
response = requests.post(
    "{{ service_base_url }}/v1/messages",
    headers={
        "x-api-key": os.environ["UNITYSVC_API_KEY"],
        "anthropic-version": "2023-06-01",
        "Content-Type": "application/json",
    },
    json={
        "model": "{{ routing_key.model }}",
        "max_tokens": 64,
        "messages": [{"role": "user", "content": "Say this is a test"}],
    },
)
response.raise_for_status()
print(response.json()["content"][0]["text"])
{% else %}
response = requests.post(
    "{{ service_base_url }}/v1/chat/completions",
    headers={
        "Authorization": f"Bearer {os.environ['UNITYSVC_API_KEY']}",
        "Content-Type": "application/json",
    },
    json={
        "model": "{{ routing_key.model }}",
        "messages": [
            {"role": "system", "content": "You are a helpful assistant."},
            {"role": "user", "content": "Say this is a test"},
        ],
    },
)
response.raise_for_status()
print(response.json()["choices"][0]["message"]["content"])
{% endif %}
