#!/bin/bash
# Embedding-shape connectivity probe: POST a one-input embedding request
# against the rendered model and assert the gateway returned a real
# ``data`` array.  Cheap, non-zero exit on any 4xx / 5xx, prints
# "connectivity ok" on success so output_contains can verify a real
# round-trip.
set -e -o pipefail

: "${UNITYSVC_API_KEY:?UNITYSVC_API_KEY is not set}"

curl --fail-with-body -sS "{{ service_base_url }}/v1/embeddings" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer ${UNITYSVC_API_KEY}" \
  -d '{"model":"{{ routing_key.model }}","input":"ping"}' \
  | grep -q '"data"'
echo "connectivity ok"
