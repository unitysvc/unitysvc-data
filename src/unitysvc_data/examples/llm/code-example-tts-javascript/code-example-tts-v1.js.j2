import { writeFile } from "fs/promises";

async function main() {
  const voice = process.env.VOICE || "alloy";
  const outputFile = process.env.OUTPUT_FILE || "tts_output.wav";

  const response = await fetch("{{ service_base_url }}/audio/speech", {
    method: "POST",
    headers: {
      Authorization: `Bearer ${process.env.UNITYSVC_API_KEY}`,
      "Content-Type": "application/json",
    },
    body: JSON.stringify({
      model: "{{ routing_key.model }}",
      input: "I love building and shipping new features for our users!",
      voice,
      response_format: "wav",
    }),
  });
  if (!response.ok) {
    throw new Error(`HTTP ${response.status}: ${await response.text()}`);
  }
  const audio = Buffer.from(await response.arrayBuffer());
  await writeFile(outputFile, audio);
  console.log(`Saved ${outputFile}`);
}

main().catch((err) => {
  console.error(err.message);
  process.exit(1);
});
