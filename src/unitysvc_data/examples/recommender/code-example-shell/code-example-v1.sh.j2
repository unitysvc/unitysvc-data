#!/bin/bash
set -e -o pipefail

: "${SERVICE_BASE_URL:?SERVICE_BASE_URL is not set}"
{% if local_testing -%}
: "${GORSE_API_KEY:?GORSE_API_KEY is not set}"
{% else -%}
: "${UNITYSVC_API_KEY:?UNITYSVC_API_KEY is not set}"
{% endif -%}
USER_ID="${USER_ID:-demo-user}"

{% if local_testing -%}
AUTH=("-H" "X-API-Key: ${GORSE_API_KEY}")
{% else -%}
AUTH=("-H" "Authorization: Bearer ${UNITYSVC_API_KEY}")
{% endif %}

# Submit feedback.
curl --fail-with-body -sS -X POST "${SERVICE_BASE_URL}/api/feedback" \
  "${AUTH[@]}" \
  -H "Content-Type: application/json" \
  -d "[{\"UserId\":\"${USER_ID}\",\"ItemId\":\"item-1\",\"FeedbackType\":\"like\"}]"
echo

# Fetch recommendations.
curl --fail-with-body -sS -X GET "${SERVICE_BASE_URL}/api/recommend/${USER_ID}?n=5" \
  "${AUTH[@]}"
echo
