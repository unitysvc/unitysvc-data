import os

import httpx

{% if local_testing %}
# Local mode: POST Telegram-format payload directly to the upstream webhook.
WEBHOOK_URL = "{{ service_base_url }}${__webhook_path__}"

response = httpx.post(
    WEBHOOK_URL,
    json={"chat_id": "${__chat_id__}", "text": "Hello from UnitySVC\nNotification delivered via transformer."},
)
response.raise_for_status()
print(f"sent (HTTP {response.status_code})")

{% else %}
# Gateway mode: POST a canonical notification envelope.
# The transformer converts it to Telegram format and forwards upstream.
GATEWAY_URL = "{{ service_base_url }}"

response = httpx.post(
    GATEWAY_URL,
    headers={"Authorization": f"Bearer {os.environ['UNITYSVC_API_KEY']}"},
    json={
        "title": "Hello from UnitySVC",
        "body": "Notification delivered via transformer.",
        "from": "user@example.com",
    },
)
response.raise_for_status()
print(f"sent (HTTP {response.status_code})")
{% endif %}
