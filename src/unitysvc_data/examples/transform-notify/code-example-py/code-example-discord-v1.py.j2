import os

import httpx

{% if local_testing %}
# Local mode: POST Discord embeds directly to the upstream webhook.
WEBHOOK_URL = "{{ service_base_url }}${__webhook_path__}"

response = httpx.post(
    WEBHOOK_URL,
    json={
        "embeds": [{
            "title": "Hello from UnitySVC",
            "description": "Notification delivered via transformer",
            "footer": {"text": "from user@example.com"},
        }]
    },
)
response.raise_for_status()
print(f"sent (HTTP {response.status_code})")

{% else %}
# Gateway mode: POST a canonical notification envelope.
# The transformer converts it to Discord embeds and forwards upstream.
GATEWAY_URL = "{{ service_base_url }}"

response = httpx.post(
    GATEWAY_URL,
    headers={"Authorization": f"Bearer {os.environ['UNITYSVC_API_KEY']}"},
    json={
        "title": "Hello from UnitySVC",
        "body": "Notification delivered via transformer.",
        "from": "user@example.com",
    },
)
response.raise_for_status()
print(f"sent (HTTP {response.status_code})")
{% endif %}
