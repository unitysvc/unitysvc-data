#!/bin/bash
# Connectivity test for notification transformer services.
# Local mode: POST the upstream notification payload directly to the HTTP upstream.
# Gateway mode: POST a canonical message envelope to the HTTP gateway endpoint.
set -o pipefail

{% if local_testing %}
# ------------------------------------------------------------------
# Local mode: verify the HTTP upstream accepts the transformer output.
# ------------------------------------------------------------------
WEBHOOK_URL="{{ service_base_url }}${__webhook_path__}"

case "${__upstream_body_type__}" in
  discord)  BODY='{"embeds":[{"title":"connectivity check","description":"ping"}]}' ;;
  slack)    BODY='{"text":"connectivity check"}' ;;
  telegram) BODY='{"chat_id":"@test","text":"connectivity check"}' ;;
  msteams)  BODY='{"type":"message","text":"connectivity check"}' ;;
  matrix)   BODY='{"msgtype":"m.text","body":"connectivity check"}' ;;
  ntfy)     BODY='{"message":"ping","title":"connectivity check"}' ;;
  gotify)   BODY='{"message":"ping","title":"connectivity check","priority":3}' ;;
  json)     BODY='{"title":"connectivity check","message":"ping"}' ;;
  *)        echo "unknown upstream_body_type: ${__upstream_body_type__}" >&2; exit 1 ;;
esac

status=$(curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -d "$BODY" \
    -o /dev/null -w "%{http_code}" \
    "$WEBHOOK_URL" 2>/dev/null)

case "$status" in
  2??) echo "connectivity ok (HTTP $status)"; exit 0 ;;
  000) echo "connectivity failed: could not connect to $WEBHOOK_URL" >&2; exit 1 ;;
  *)   echo "connectivity failed: HTTP $status from $WEBHOOK_URL" >&2; exit 1 ;;
esac

{% else %}
# ------------------------------------------------------------------
# Gateway mode: send a canonical envelope to the HTTP gateway endpoint.
# ------------------------------------------------------------------
GATEWAY_URL="{{ service_base_url }}"

status=$(curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer ${UNITYSVC_API_KEY}" \
    -d '{"title":"connectivity check","body":"ping","from":"test@example.com"}' \
    -o /dev/null -w "%{http_code}" \
    "$GATEWAY_URL" 2>/dev/null)

case "$status" in
  2??) echo "connectivity ok (HTTP $status)"; exit 0 ;;
  000) echo "connectivity failed: could not connect to $GATEWAY_URL" >&2; exit 1 ;;
  *)   echo "connectivity failed: HTTP $status from $GATEWAY_URL" >&2; exit 1 ;;
esac
{% endif %}
