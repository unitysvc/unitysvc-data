#!/bin/bash
# Code example for SMTP→Slack-compatible transformer services (slack, mattermost, rocketchat, gchat, flock, webex, notifico).
set -o pipefail

{% if local_testing %}
WEBHOOK_URL="{{ service_base_url }}${__webhook_path__}"

status=$(curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -d '{"text":"Hello from UnitySVC","username":"unitysvc"}' \
    -o /dev/null -w "%{http_code}" \
    "$WEBHOOK_URL" 2>/dev/null)

case "$status" in
  2??) echo "sent"; exit 0 ;;
  000) echo "request failed: could not connect to $WEBHOOK_URL" >&2; exit 1 ;;
  *)   echo "request failed: HTTP $status from $WEBHOOK_URL" >&2; exit 1 ;;
esac

{% else %}
GATEWAY_URL="{{ service_base_url }}"

curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer ${UNITYSVC_API_KEY}" \
    -d '{
  "title": "Hello from UnitySVC",
  "body": "Notification delivered via transformer.",
  "from": "user@example.com"
}' \
    -w "\nHTTP %{http_code}\n" \
    "$GATEWAY_URL"

echo "sent"
{% endif %}
