#!/bin/bash
# Code example for SMTP→Resend transformer services.
set -o pipefail

{% if local_testing %}
WEBHOOK_URL="{{ service_base_url }}${{'__webhook_path__'}}"

curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -d '{"from":"test@example.com","to":["test@example.com"],"subject":"connectivity check","text":"ping"}' \
    -w "\nHTTP %{http_code}\n" \
    "$WEBHOOK_URL"

echo "sent"

{% else %}
GATEWAY_URL="{{ service_base_url }}"

curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer ${UNITYSVC_API_KEY}" \
    -d '{"title":"connectivity check","body":"ping","from":"test@example.com"}' \
    -w "\nHTTP %{http_code}\n" \
    "$GATEWAY_URL"

echo "sent"
{% endif %}
