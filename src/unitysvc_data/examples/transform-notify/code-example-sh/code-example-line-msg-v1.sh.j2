#!/bin/bash
# Code example for SMTP→LINE transformer services.
set -o pipefail

{% if local_testing %}
WEBHOOK_URL="{{ service_base_url }}${{'__webhook_path__'}}"

curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -d '{"to":"Utest","messages":[{"type":"text","text":"connectivity check"}]}' \
    -w "\nHTTP %{http_code}\n" \
    "$WEBHOOK_URL"

echo "sent"

{% else %}
GATEWAY_URL="{{ service_base_url }}"

curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer ${UNITYSVC_API_KEY}" \
    -d '{"title":"connectivity check","body":"ping","from":"test@example.com"}' \
    -w "\nHTTP %{http_code}\n" \
    "$GATEWAY_URL"

echo "sent"
{% endif %}
