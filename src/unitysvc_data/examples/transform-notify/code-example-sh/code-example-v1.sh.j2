#!/bin/bash
# Code example for notification transformer services.
# Local mode: POST the upstream notification payload directly to the HTTP upstream.
# Gateway mode: POST a canonical message envelope to the HTTP gateway endpoint.
set -o pipefail

{% if local_testing %}
# ------------------------------------------------------------------
# Local mode: POST the upstream payload the transformer will deliver.
# ------------------------------------------------------------------
WEBHOOK_URL="{{ service_base_url }}${__webhook_path__}"

case "${__upstream_body_type__}" in
  discord)
    BODY='{
  "embeds": [{
    "title": "Hello from UnitySVC",
    "description": "Notification delivered via transformer",
    "footer": {"text": "from user@example.com"}
  }]
}'
    ;;
  slack)
    BODY='{"text": "Hello from UnitySVC: Notification delivered via transformer"}'
    ;;
  telegram)
    BODY='{"chat_id": "@channel", "text": "Hello from UnitySVC: Notification delivered via transformer"}'
    ;;
  msteams)
    BODY='{"type": "message", "text": "Hello from UnitySVC: Notification delivered via transformer"}'
    ;;
  matrix)
    BODY='{"msgtype": "m.text", "body": "Hello from UnitySVC: Notification delivered via transformer"}'
    ;;
  ntfy)
    BODY='{"message": "Notification delivered via transformer", "title": "Hello from UnitySVC"}'
    ;;
  gotify)
    BODY='{"message": "Notification delivered via transformer", "title": "Hello from UnitySVC", "priority": 5}'
    ;;
  json)
    BODY='{"title": "Hello from UnitySVC", "message": "Notification delivered via transformer"}'
    ;;
  *)
    echo "unknown upstream_body_type: ${__upstream_body_type__}" >&2; exit 1
    ;;
esac

curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -d "$BODY" \
    -w "\nHTTP %{http_code}\n" \
    "$WEBHOOK_URL"

echo "sent"

{% else %}
# ------------------------------------------------------------------
# Gateway mode: POST a canonical notification envelope.
# The transformer converts it and forwards to the configured upstream.
# ------------------------------------------------------------------
GATEWAY_URL="{{ service_base_url }}"

curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer ${UNITYSVC_API_KEY}" \
    -d '{
  "title": "Hello from UnitySVC",
  "body": "Notification delivered via transformer.",
  "from": "user@example.com"
}' \
    -w "\nHTTP %{http_code}\n" \
    "$GATEWAY_URL"

echo "sent"
{% endif %}
