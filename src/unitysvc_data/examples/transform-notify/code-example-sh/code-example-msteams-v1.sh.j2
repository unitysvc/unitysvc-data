#!/bin/bash
# Code example for SMTP→MS Teams (webhookb2) transformer services.
set -o pipefail

{% if local_testing %}
WEBHOOK_URL="{{ service_base_url }}${__webhook_path__}"

curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -d '{
  "@type": "MessageCard",
  "@context": "https://schema.org/extensions",
  "themeColor": "0076D7",
  "text": "Hello from UnitySVC",
  "sections": [{"activityText": "Notification delivered via transformer."}]
}' \
    -w "\nHTTP %{http_code}\n" \
    "$WEBHOOK_URL"

echo "sent"

{% else %}
GATEWAY_URL="{{ service_base_url }}"

curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer ${UNITYSVC_API_KEY}" \
    -d '{
  "title": "Hello from UnitySVC",
  "body": "Notification delivered via transformer.",
  "from": "user@example.com"
}' \
    -w "\nHTTP %{http_code}\n" \
    "$GATEWAY_URL"

echo "sent"
{% endif %}
