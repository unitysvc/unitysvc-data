#!/bin/bash
# Code example for SMTP→Discord transformer services.
# Local mode: POST a Discord embeds payload directly to the upstream webhook.
# Gateway mode: POST a canonical envelope to the HTTP gateway endpoint.
set -o pipefail

{% if local_testing %}
WEBHOOK_URL="{{ service_base_url }}${__webhook_path__}"

curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -d '{
  "embeds": [{
    "title": "Hello from UnitySVC",
    "description": "Notification delivered via transformer",
    "footer": {"text": "from user@example.com"}
  }]
}' \
    -w "\nHTTP %{http_code}\n" \
    "$WEBHOOK_URL"

echo "sent"

{% else %}
GATEWAY_URL="{{ service_base_url }}"

curl -sS --max-time 10 \
    -X POST \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer ${UNITYSVC_API_KEY}" \
    -d '{
  "title": "Hello from UnitySVC",
  "body": "Notification delivered via transformer.",
  "from": "user@example.com"
}' \
    -w "\nHTTP %{http_code}\n" \
    "$GATEWAY_URL"

echo "sent"
{% endif %}
