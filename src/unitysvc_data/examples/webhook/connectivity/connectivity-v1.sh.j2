#!/bin/bash
# Connectivity test for Discord-compatible webhook endpoints. POSTs a
# minimal embeds payload and asserts HTTP 204 (Discord's success code).
set -o pipefail

WEBHOOK_URL="{{ service_base_url }}${__webhook_path__}"

status=$(curl -sS --max-time 5 \
    -X POST \
    -H "Content-Type: application/json" \
    -d '{"embeds":[{"title":"connectivity check","description":"ping"}]}' \
    -o /dev/null -w "%{http_code}" \
    "$WEBHOOK_URL" 2>/dev/null)

case "$status" in
  204)
    echo "connectivity ok (HTTP $status)"
    exit 0
    ;;
  000)
    echo "connectivity failed: could not connect to $WEBHOOK_URL" >&2
    exit 1
    ;;
  *)
    echo "connectivity failed: HTTP $status from $WEBHOOK_URL" >&2
    exit 1
    ;;
esac
